# Data-agent (opencode + GPT-5.5) and judge credentials.
OPENAI_API_KEY=sk-...
DATA_AGENT_MODEL=gpt-5.5
JUDGE_MODEL=gpt-5.5

# Optional: cap how long the data-agent's opencode run may take, in seconds.
DATA_AGENT_OPENCODE_TIMEOUT=600

# Select one problem per run.
BIOEVAL_PROBLEM_ID=s41467-026-73635-7_butterfly-longevity-pollen-feeding
# Use `bioeval-init-run` to create a unique id, or leave unset for ad-hoc runs.
BIOEVAL_RUN_ID=

# Optional: separate key exposed to the UEA container if the UEA itself uses OpenAI.
UEA_OPENAI_API_KEY=

# UEA container resource budget (enforced by check_space; disk quota is best-effort).
BIOEVAL_DISK_BUDGET_GB=20
BIOEVAL_MEM_LIMIT=8g
BIOEVAL_CPUS=4
