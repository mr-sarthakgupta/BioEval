# Experiment-agent uses AWS Bedrock Sonnet 4.6 by default. You can provide either
# AWS_BEARER_TOKEN_BEDROCK or an ABSK... token in ~/.aws/credentials as
# aws_session_token, matching skydiscover's Bedrock setup.
# Optional: only needed for OpenAI-compatible experiment-agent fallback paths.
OPENAI_API_KEY=sk-...
OPENALEX_API_KEY=
# Alternatively, point Compose at a host key file.
OPENALEX_API_KEY_FILE=/home/mrsar/openalex_key.txt
EXPERIMENT_AGENT_MODEL=us.anthropic.claude-sonnet-4-6
EXPERIMENT_AGENT_API_BASE=bedrock:us-east-1
AWS_REGION=us-east-1
BEDROCK_AWS_REGION=us-east-1

# Experiment data grants remain tightly bounded after feasibility validation.
BIOEVAL_MAX_DATASET_GRANTS_PER_REQUEST=1

# Host-side traffic guard for UEA web/literature/fetch tools. The deterministic
# marker/domain filters run first; remaining traffic is reviewed by a guard-agent
# that blocks the held-out paper and derivatives while allowing predecessor work.
# Keep fail-closed enabled for benchmark runs.
BIOEVAL_TRAFFIC_GUARD_ENABLED=1
BIOEVAL_TRAFFIC_GUARD_FAIL_CLOSED=1
BIOEVAL_TRAFFIC_GUARD_MODEL=us.anthropic.claude-sonnet-4-6
BIOEVAL_TRAFFIC_GUARD_API_BASE=bedrock:us-east-1

# Private OpenAlex citation closure. The target work and all discovered incoming
# citation descendants up to these safety caps are blocked before LLM review.
BIOEVAL_OPENALEX_DESCENDANT_DEPTH=20
BIOEVAL_OPENALEX_DESCENDANT_MAX_NODES=10000
BIOEVAL_OPENALEX_GRAPH_CACHE_TTL=21600

# Judge uses AWS Bedrock Sonnet 4.6 with prompt caching, like the UEA.
JUDGE_MODEL=us.anthropic.claude-sonnet-4-6
JUDGE_API_BASE=bedrock:us-east-1
JUDGE_MAX_TOKENS=8192
JUDGE_TEMPERATURE=0

# Agent-under-evaluation defaults used by `bioeval-run-bedrock-uea`.
UEA_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
UEA_BEDROCK_API_BASE=bedrock:us-east-1
UEA_MAX_STEPS=40
UEA_MAX_TOKENS=8192
UEA_TEMPERATURE=0.2

# Optional: cap how long the experiment-agent's planner may take, in seconds.
EXPERIMENT_AGENT_OPENCODE_TIMEOUT=600

# Select one problem per run.
BIOEVAL_PROBLEM_ID=s41467-026-73635-7_butterfly-longevity-pollen-feeding
# `bioeval-init-run` prints the correct value for the selected problem.
BIOEVAL_PROBLEMS_DIR=problems_complete
# Use `bioeval-init-run` to create a unique id, or leave unset for ad-hoc runs.
BIOEVAL_RUN_ID=

# Optional: separate key exposed to the UEA container if the UEA itself uses OpenAI.
UEA_OPENAI_API_KEY=

# UEA container resource budget (enforced by check_space; disk quota is best-effort).
BIOEVAL_DISK_BUDGET_GB=20
BIOEVAL_MEM_LIMIT=8g
BIOEVAL_CPUS=4
