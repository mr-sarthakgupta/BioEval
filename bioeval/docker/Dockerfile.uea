FROM python:3.11-slim

ARG OPENCODE_INSTALL_URL=https://opencode.ai/install

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    file \
    git \
    jq \
    libseccomp2 \
    nodejs \
    npm \
    procps \
    r-base-core \
    ripgrep \
    unzip \
    util-linux \
    vim-common \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    boto3 \
    biopython \
    jupyter \
    lifelines \
    matplotlib \
    numpy \
    openpyxl \
    pandas \
    pyarrow \
    requests \
    scikit-learn \
    scipy \
    statsmodels

# OpenCode installation changes over time; keep it isolated so users can override
# OPENCODE_INSTALL_URL at build time if the upstream installer moves.
RUN curl -fsSL "${OPENCODE_INSTALL_URL}" | bash || true

COPY bioeval/container_tools/design_experiment.py /usr/local/bin/design_experiment
COPY bioeval/container_tools/experiment_contract.py /usr/local/bin/experiment_contract.py
COPY bioeval/container_tools/submit_answer.py /usr/local/bin/submit_answer
COPY bioeval/container_tools/check_space.py /usr/local/bin/check_space
COPY bioeval/container_tools/record_event.py /usr/local/bin/record_event
COPY bioeval/container_tools/record_shell_command.py /usr/local/bin/record_shell_command
COPY bioeval/container_tools/bioeval_session /usr/local/bin/bioeval_session
COPY bioeval/container_tools/bioeval_tool_common.py /usr/local/bin/bioeval_tool_common.py
COPY bioeval/container_tools/read_file.py /usr/local/bin/read_file
COPY bioeval/container_tools/search.py /usr/local/bin/search
COPY bioeval/container_tools/web_search.py /usr/local/bin/web_search
COPY bioeval/container_tools/fetch_webpage.py /usr/local/bin/fetch_webpage
COPY bioeval/container_tools/research_papers.py /usr/local/bin/research_papers
COPY bioeval/container_tools/run_command.py /usr/local/bin/run_command
COPY bioeval/container_tools/restricted_python.py /usr/local/bin/restricted_python
COPY bioeval/container_tools/sandbox_exec.py /usr/local/bin/sandbox_exec
COPY bioeval/bedrock_cost.py /usr/local/bin/bedrock_cost.py
COPY bioeval/container_tools/uea_bedrock_agent.py /usr/local/bin/uea_bedrock_agent
RUN chmod +x /usr/local/bin/design_experiment /usr/local/bin/submit_answer /usr/local/bin/check_space /usr/local/bin/record_event /usr/local/bin/record_shell_command /usr/local/bin/bioeval_session /usr/local/bin/read_file /usr/local/bin/search /usr/local/bin/web_search /usr/local/bin/fetch_webpage /usr/local/bin/research_papers /usr/local/bin/run_command /usr/local/bin/restricted_python /usr/local/bin/sandbox_exec /usr/local/bin/uea_bedrock_agent

WORKDIR /workspace
ENV EXPERIMENT_AGENT_URL=http://experiment-agent:8765/experiments
ENV UEA_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
ENV UEA_BEDROCK_API_BASE=bedrock:us-east-1
ENV BIOEVAL_DISK_BUDGET_GB=20
ENV BIOEVAL_SUBMIT_DIR=/submit

CMD ["/bin/bash"]
