FROM python:3.11-slim

ARG OPENCODE_INSTALL_URL=https://opencode.ai/install

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml /app/
COPY bioeval /app/bioeval
RUN pip install --no-cache-dir -e . \
    && pip install --no-cache-dir pandas pyarrow openpyxl

# OpenAI-compatible configs can still reason through opencode. Bedrock defaults use
# boto3 directly.
RUN curl -fsSL "${OPENCODE_INSTALL_URL}" | bash || true
ENV PATH="/root/.opencode/bin:${PATH}"

EXPOSE 8765
ENTRYPOINT ["bioeval-experiment-agent"]
